# ─── Exchange ────────────────────────────────────────────────────────────────
# Any CCXT-supported exchange ID: bybit, okx, kraken, coinbase, binance, ...
EXCHANGE_ID=coinbase

# API credentials (read-only keys are enough for internal paper mode)
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here

# Coinbase Advanced Trade (CDP): paste the full multi-line ECDSA private key as-is.
# The bot normalises \n escape sequences automatically.

# ─── Paper Trading Mode ──────────────────────────────────────────────────────
# internal (default) — fills simulated locally, works on every exchange
# sandbox            — uses CCXT testnet mode (not supported by all exchanges)
# live               — real orders, requires ALLOW_LIVE=1
PAPER_MODE=internal
ALLOW_LIVE=0

# ─── Trading Parameters ──────────────────────────────────────────────────────
TRADING_SYMBOL=BTC/USDT
TIMEFRAME=15m

# Loop interval in seconds. Leave blank to auto-align with candle close.
LOOP_INTERVAL=

# ─── Strategy Tuning ─────────────────────────────────────────────────────────
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# ─── Risk / Sizing ───────────────────────────────────────────────────────────
MAX_PORTFOLIO_RISK_PER_TRADE=0.02
POSITION_SIZE_USD=100.0
PAPER_BALANCE_USD=10000.0
